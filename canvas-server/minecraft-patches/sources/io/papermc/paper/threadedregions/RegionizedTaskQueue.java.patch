+                final var current = TickRegionScheduler.getCurrentRegion();
+                if (owner == current) {
+                    return false;
+                }
+                this.run = null;
+                final var unsyncOwner = level.regioniser.getRegionAtUnsynchronised(this.chunkX, this.chunkZ);
