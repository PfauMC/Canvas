+    private static final int RECENT_OPS_CAP = 48;
+    private final java.util.concurrent.ConcurrentLinkedDeque<String> recentStructuralOps = new java.util.concurrent.ConcurrentLinkedDeque<>();
+    private final AtomicLong structuralOpSeq = new AtomicLong();
+
+    public void recordStructuralOp(final String op) {
+        final long seq = this.structuralOpSeq.incrementAndGet();
+        this.recentStructuralOps.addLast(seq + " t=" + System.nanoTime() + " [" + Thread.currentThread().getName() + "] " + op);
+        while (this.recentStructuralOps.size() > RECENT_OPS_CAP) {
+            this.recentStructuralOps.pollFirst();
+        }
+    }
+
+    public String debugRecentStructuralOps() {
+        final StringBuilder sb = new StringBuilder(2048);
+        for (final String s : this.recentStructuralOps) {
+            sb.append("    ").append(s).append('\n');
+        }
+        return sb.length() == 0 ? "    (none)\n" : sb.toString();
+    }
